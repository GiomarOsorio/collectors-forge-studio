# Build stage
FROM docker.io/node:20-alpine AS build

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

# Verify that critical deps actually resolved (busts the build early con
# error legible si el cache de podman/npm dejó un node_modules incompleto).
RUN npm ls @dnd-kit/core @dnd-kit/sortable @dnd-kit/utilities react-router-dom \
    || (echo "ERROR: deps faltantes tras npm ci. Revisar cache podman." && exit 1)

COPY . .
RUN npm run build

# Production stage
FROM docker.io/nginx:alpine

COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
