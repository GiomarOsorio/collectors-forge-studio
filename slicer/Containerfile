FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive
ENV DISPLAY=

# Dependencias del sistema
# GTK3 y libs de display son necesarias porque OrcaSlicer las enlaza dinámicamente
# incluso en modo CLI (--slice). Las AppImages de OrcaSlicer no empaquetan GTK.
RUN apt-get update && apt-get install -y \
    wget curl python3.12 python3-pip python3.12-venv \
    libgl1 libglx-mesa0 libglu1-mesa libgles2 \
    libx11-6 libxrender1 libxi6 libxext6 \
    libdbus-1-3 libfontconfig1 libfreetype6 \
    libglib2.0-0 libgomp1 \
    libgtk-3-0 libgdk-pixbuf-2.0-0 \
    libatk1.0-0 libpango-1.0-0 libcairo2 \
    libxcomposite1 libxdamage1 libxfixes3 libxrandr2 \
    ca-certificates libgstreamer1.0-0 libgstreamer-plugins-base1.0-0 \
    libwebkit2gtk-4.1-0 \
    && rm -rf /var/lib/apt/lists/*

# Descargar y extraer OrcaSlicer nightly (AppImage Ubuntu 24.04)
# El AppImage se extrae con --appimage-extract porque FUSE no esta en contenedores.
# Se enlaza a AppRun (no al binario directamente) para que configure LD_LIBRARY_PATH
# con las libs empaquetadas dentro del AppImage antes de lanzar el binario.
# REBUILD: 2026-02-26 — forzar descarga de nightly reciente (>=2.5.x) para
# compatibilidad con archivos de MakerWorld creados con OrcaSlicer 2.5.x
RUN wget -q -O /tmp/OrcaSlicer.AppImage \
    "https://github.com/OrcaSlicer/OrcaSlicer/releases/download/nightly-builds/OrcaSlicer_Linux_AppImage_Ubuntu2404_nightly.AppImage" \
    && chmod +x /tmp/OrcaSlicer.AppImage \
    && cd /opt && /tmp/OrcaSlicer.AppImage --appimage-extract \
    && rm /tmp/OrcaSlicer.AppImage \
    && test -f /opt/squashfs-root/AppRun \
    && chmod +x /opt/squashfs-root/AppRun \
    && ln -sf /opt/squashfs-root/AppRun /usr/local/bin/OrcaSlicer

# Mismo usuario que el backend (UID 1000) para compartir slicer_jobs sin conflictos de permisos.
# Ubuntu 24.04 incluye un usuario 'ubuntu' con UID 1000 en la imagen base,
# por lo que no se puede hacer useradd directo. Si UID 1000 ya existe se renombra
# ese usuario a appuser; si no existe se crea desde cero.
RUN if id -u 1000 >/dev/null 2>&1; then \
        OLDNAME=$(id -nu 1000); \
        usermod --login appuser --shell /bin/false "$OLDNAME"; \
        groupmod --new-name appuser "$OLDNAME"; \
    else \
        useradd --no-create-home --shell /bin/false --uid 1000 appuser; \
    fi

# Instalar dependencias Python del wrapper FastAPI
WORKDIR /app
COPY requirements.txt .
RUN python3 -m pip install --no-cache-dir --break-system-packages -r requirements.txt

# Copiar aplicacion wrapper
COPY app.py .
RUN chown -R appuser:appuser /app

# Volumen para archivos de trabajos (compartido con el backend)
RUN mkdir -p /slicer_jobs && chown appuser:appuser /slicer_jobs
VOLUME ["/slicer_jobs"]

EXPOSE 8001

USER appuser

CMD ["python3", "-m", "uvicorn", "app:app", "--host", "0.0.0.0", "--port", "8001"]
