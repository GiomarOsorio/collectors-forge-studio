# Collector's Forge Studio - Variables de entorno para producción
# Copiar este archivo como ~/CollectorsForgeENV y completar los valores

# ── Obligatorias ──────────────────────────────────────────────────────────────
# Clave JWT (generar con: openssl rand -hex 32)
SECRET_KEY=

# Contraseña de PostgreSQL
POSTGRES_PASSWORD=

# Clave para SessionMiddleware (generar con: openssl rand -hex 32)
# Si se omite, se usa SECRET_KEY
SESSION_SECRET_KEY=

# ── OIDC / SSO (Authentik u otro proveedor OIDC) ─────────────────────────────
# URL del issuer — en Authentik: https://auth.tudominio.com/application/o/<slug>/
# (incluye la barra final)
OIDC_ISSUER=

# Client ID y Client Secret de la aplicación creada en Authentik
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# Redirect URI registrada en Authentik
# Debe coincidir exactamente con lo configurado en el proveedor
OIDC_REDIRECT_URI=https://cfs.turtlenode.dev/api/auth/oidc/callback

# Nota: el Cloudflare Tunnel lo gestiona service-deployments (cloudflared.container),
# no este repo. Configurar el hostname cfs.turtlenode.dev → http://cfs-app:8000
# en el dashboard de Cloudflare, y redesplegar service-deployments.

# ── Opcionales (tienen defaults razonables) ───────────────────────────────────
POSTGRES_USER=collectorsforge
POSTGRES_DB=collectorsforge
POSTGRES_HOST=cfs-postgres
POSTGRES_PORT=5432
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
