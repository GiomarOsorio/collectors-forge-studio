# Calculator3D - Variables de entorno para producción
# Copiar este archivo como .env y completar los valores

# Clave secreta para JWT (generar una con: openssl rand -hex 32)
SECRET_KEY=

# Credenciales del admin inicial
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_EMAIL=admin@turtlenode.dev

# Cloudflare Tunnel Token
# Obtener desde: https://one.dash.cloudflare.com → Networks → Tunnels → Create
# Public hostname: 3d.turtlenode.dev → http://calculator3d-frontend:80
TUNNEL_TOKEN=
